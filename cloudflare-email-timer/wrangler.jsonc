{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "work-journal-email-timer",
  "main": "src/index.js",
  "compatibility_date": "2026-06-17",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "triggers": {
    // Keep the default environment unscheduled; production owns the weekly trigger.
    "crons": []
  },
  "vars": {
    "GITHUB_REPO": "a16638047141/work-journal",
    "GITHUB_WORKFLOW": "send-weekly-report.yml",
    "GITHUB_REF": "main",
    "TRIGGER_SOURCE": "timer"
  },
  "env": {
    "prod": {
      "workers_dev": false,
      "triggers": {
        // Production schedule: Saturday 08:00 in Asia/Shanghai. Cloudflare cron uses UTC.
        "crons": ["0 0 * * 6"]
      },
      "vars": {
        "GITHUB_REPO": "a16638047141/work-journal",
        "GITHUB_WORKFLOW": "send-weekly-report.yml",
        "GITHUB_REF": "main",
        "TRIGGER_SOURCE": "timer"
      }
    }
  }
}
